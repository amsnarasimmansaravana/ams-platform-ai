<mxfile><diagram name="AI HR System"><mxGraphModel><root><mxCell id="0" /><mxCell id="1" parent="0" /><mxCell id="2" value="AI-Driven HR Multi-Agent Orchestration System&#10;Created by Narasimman Saravana | GenAI Architect" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;" vertex="1" parent="1"><mxGeometry x="50" y="20" width="900" height="80" as="geometry" /></mxCell><mxCell id="3" value="Requisition&#10;- JD Input&#10;- Identity Resolution&#10;- Duplicate Check&#10;- Structured JD" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;" vertex="1" parent="1"><mxGeometry x="50" y="120" width="180" height="200" as="geometry" /></mxCell><mxCell id="4" value="Sourcing&#10;- Candidate Ingestion (LinkedIn, Naukri, Referral)&#10;- Identity Resolution&#10;- Merge Profiles" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;" vertex="1" parent="1"><mxGeometry x="250" y="120" width="200" height="200" as="geometry" /></mxCell><mxCell id="5" value="Parsing&#10;- Resume Parsing Agent&#10;- Extract Skills, Experience&#10;- Confidence Check&#10;- Human Review if Low" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;" vertex="1" parent="1"><mxGeometry x="480" y="120" width="200" height="200" as="geometry" /></mxCell><mxCell id="6" value="Screening&#10;- Embedding + LLM&#10;- Score Evaluation&#10;- &lt;60 Reject&#10;- 60-75 Review&#10;- &gt;75 Shortlist" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;" vertex="1" parent="1"><mxGeometry x="710" y="120" width="200" height="200" as="geometry" /></mxCell><mxCell id="7" value="Interview&#10;- Adaptive Q&amp;A&#10;- AI Confidence&#10;- Human Interview Review&#10;- Feedback Analysis" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;" vertex="1" parent="1"><mxGeometry x="940" y="120" width="200" height="200" as="geometry" /></mxCell><mxCell id="8" value="Decision&#10;- AI + Human Scores&#10;- Conflict Detection&#10;- Hiring Committee&#10;- Final Decision" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;" vertex="1" parent="1"><mxGeometry x="1170" y="120" width="200" height="200" as="geometry" /></mxCell><mxCell id="9" value="Offer&#10;- Offer Generation&#10;- Risk Prediction&#10;- HR Engagement&#10;- Acceptance Tracking" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;" vertex="1" parent="1"><mxGeometry x="1400" y="120" width="200" height="200" as="geometry" /></mxCell><mxCell id="10" value="Failure Scenarios&#10;- Duplicate Candidates&#10;- Parsing Errors&#10;- Poor Screening&#10;- Interview Bias&#10;- Offer Drop-offs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;" vertex="1" parent="1"><mxGeometry x="50" y="350" width="400" height="180" as="geometry" /></mxCell><mxCell id="11" value="Human-AI Interaction&#10;- JD Refinement&#10;- Candidate Enrichment&#10;- Decision Override&#10;- System Feedback" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;" vertex="1" parent="1"><mxGeometry x="500" y="350" width="400" height="180" as="geometry" /></mxCell><mxCell id="12" value="Continuous Learning&#10;- Post-hire Performance&#10;- Attrition Tracking&#10;- Model Updates&#10;- Threshold Tuning" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;" vertex="1" parent="1"><mxGeometry x="950" y="350" width="400" height="180" as="geometry" /></mxCell></root></mxGraphModel></diagram></mxfile>