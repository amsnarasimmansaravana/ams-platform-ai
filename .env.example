# AMS-AI microservices — copy to `.env` at repo root. Prefix: AMS_
#
# Gateway (services/gateway) — downstream service base URLs (no trailing slash):
# AMS_AGENT_SERVICE_URL=http://127.0.0.1:8001
# AMS_ORCHESTRATION_SERVICE_URL=http://127.0.0.1:8002
# AMS_TOOL_SERVICE_URL=http://127.0.0.1:8003
# AMS_EXECUTION_SERVICE_URL=http://127.0.0.1:8004
#
# In Docker Compose these are set automatically to http://<service-name>:8000
#
# Shared (all services):
# AMS_SERVICE_NAME=my-service
# AMS_ENVIRONMENT=development
# AMS_LOG_LEVEL=INFO
# AMS_LOG_JSON=false
#
# Future persistence:
# AMS_DATABASE_URL=postgresql+asyncpg://ams:ams@localhost:5432/ams_ai
# AMS_REDIS_URL=redis://localhost:6379/0
